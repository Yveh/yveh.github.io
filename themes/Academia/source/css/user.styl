// Custom styles for Yuheng Zhang homepage

// Right-aligned italic date marker used inline in lists
.date
  color #888
  font-style italic
  font-size 0.92em

// Publication list — tighter, numbered, with breathing room between entries
ol.pub-list
  padding-left 1.4em
  li
    margin-bottom 1.0em
    line-height 1.55
    strong
      font-weight 600
    u
      text-decoration underline

// Slightly tighter section spacing
.page h2
  margin-top 1.6em
  margin-bottom 0.6em
.page h2:first-child
  margin-top 0.4em

// Cleaner list spacing
.page ul li
  margin-bottom 0.4em
